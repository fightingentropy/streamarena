{
  "name": "streamarena-app",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "./scripts/dev-rust.sh",
    "dev:rust": "cargo run",
    "dev:vite": "vite",
    "test:rust": "cargo test",
    "test:worker": "node --test workers/live-hls-proxy/test/*.test.mjs",
    "lint:frontend": "node ./scripts/check-js-syntax.mjs",
    "test:frontend:unit": "node ./scripts/auth-local-state-test.mjs && node ./scripts/subtitle-offset-test.mjs && node ./scripts/offline-artwork-test.mjs && node ./scripts/media-track-labels-test.mjs",
    "test:frontend": "bun run test:frontend:unit && node ./scripts/frontend-smoke.mjs",
    "test": "bun run test:rust && bun run test:worker && bun run test:frontend",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --all-targets --all-features -- -D warnings",
    "audit:rust": "cargo audit --no-fetch",
    "check:quality": "bun run check:rust && bun run audit:rust",
    "check:architecture": "node ./scripts/check-architecture.mjs",
    "check": "bun run lint:frontend && bun run build && bun run check:architecture && bun run test:rust && bun run test:worker && bun run test:frontend",
    "build": "vite build",
    "preview": "vite preview",
    "mini:deploy": "./scripts/deploy-mini.sh",
    "mini:check": "./scripts/check-mini.sh",
    "mini:backup": "./scripts/backup-mini.sh",
    "mini:install-server": "./scripts/install-mini-server.sh",
    "mini:install-agents": "./scripts/install-mini-agents.sh",
    "mini:map-ports": "./scripts/map-mini-ports.sh",
    "mini:update-dns": "./scripts/update-mini-dns.sh",
    "bench:playback": "node ./scripts/playback-benchmark.mjs",
    "bench:load": "node ./scripts/playback-load-benchmark.mjs",
    "bench:resolve": "node ./scripts/resolver-load-benchmark.mjs",
    "bench:playback:install": "playwright install chromium"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "libsodium-wrappers": "^0.8.4",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "rollup": "^4.60.4"
  }
}
