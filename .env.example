TMDB_API_KEY=your_tmdb_v3_api_key_or_v4_read_access_token_here
REAL_DEBRID_TOKEN=your_real_debrid_api_token_here
OPENSUBTITLES_API_KEY=your_opensubtitles_api_key_here
OPENSUBTITLES_USER_AGENT=netflix-rust-backend v1.0.0
TORRENTIO_BASE_URL=https://torrentio.strem.fun
# Optional generic Torznab fallback discovery backend.
# Works with Prowlarr, Jackett, or another Torznab-compatible endpoint.
# Prefer a filtered/specific indexer endpoint over Jackett's broad `all` endpoint.
# Examples:
# TORZNAB_API_URL=http://127.0.0.1:9696/1/api
# TORZNAB_API_URL=http://127.0.0.1:9117/api/v2.0/indexers/yts/results/torznab/api
TORZNAB_API_URL=
TORZNAB_API_KEY=
TORZNAB_MOVIE_CATEGORIES=2000,2040,2045
TORZNAB_TV_CATEGORIES=5000,5040,5045
TORZNAB_LIMIT=50
TORZNAB_TIMEOUT_MS=15000
HOST=127.0.0.1
PORT=5173
# Route server outbound HTTP through a VPN/proxy (SOCKS5 or HTTP).
# Example: socks5://127.0.0.1:1080
OUTBOUND_HTTP_PROXY=
# Route only sports provider HTTP/browser resolver traffic through a VPN/proxy.
# Example with WARP proxy mode: socks5://127.0.0.1:40000
SPORTS_HTTP_PROXY=
# Proxy movie embed iframe HTML through the server when explicitly enabled.
# Values: 1/true/on | 0/false/off
EMBED_IFRAME_PROXY=0
# Optional Playwright resolver scripts for embed providers. Set to 0/off to disable.
EXTERNAL_EMBED_HLS_RESOLVER_SCRIPT=scripts/resolve-external-embed-hls.mjs
EXTERNAL_EMBED_HLS_RESOLVE_TIMEOUT_MS=24000
STREAMED_HLS_RESOLVER_SCRIPT=scripts/resolve-streamed-hls.mjs
# Optional browser-only proxy overrides for the embed resolver scripts.
EXTERNAL_EMBED_BROWSER_PROXY=
STREAMED_EMBED_BROWSER_PROXY=
# Maximum upload body size (bytes). Increase if large videos fail with HTTP 413.
MAX_UPLOAD_BYTES=10737418240
# HLS transcoding acceleration mode: none | auto | videotoolbox | cuda | qsv
# Use `auto` on macOS to prefer VideoToolbox.
HLS_HWACCEL=auto
# Hard cap for simultaneous full-title HLS transcode workers.
HLS_MAX_TRANSCODE_JOBS=1
# Hard cap for simultaneous on-demand HLS segment renders.
HLS_MAX_SEGMENT_RENDERS=2
# How long a segment request can wait for an on-demand render slot.
HLS_SEGMENT_QUEUE_TIMEOUT_MS=2000
# Remux normalize acceleration mode: none | auto | videotoolbox | cuda | qsv
# Falls back to HLS_HWACCEL when unset.
REMUX_HWACCEL=auto
# Enable server-side automatic A/V delay compensation during remux (0/1).
# Keep enabled to auto-correct common source timestamp drift.
AUTO_AUDIO_SYNC=1
# Remux video handling mode: auto | copy | normalize
# `auto` uses full video timestamp rebuild for MKV/WebM-like sources.
REMUX_VIDEO_MODE=auto
# Hard cap for simultaneous server-side remux ffmpeg processes.
REMUX_MAX_CONCURRENT=2
# How long a remux request waits for an open slot before returning HTTP 429.
REMUX_QUEUE_TIMEOUT_MS=2000
# Max lifetime for one remux ffmpeg process.
REMUX_PROCESS_TIMEOUT_SECONDS=14400
# Hard cap for simultaneous fresh external resolver work.
RESOLVER_MAX_CONCURRENT=2
# How long a resolver request waits for an open external slot before HTTP 429.
RESOLVER_QUEUE_TIMEOUT_MS=3000
# Max local torrent/direct-cache disk budget and first-byte wait windows.
LOCAL_TORRENT_MAX_BYTES=85899345920
LOCAL_TORRENT_METADATA_TIMEOUT_MS=20000
LOCAL_TORRENT_READY_TIMEOUT_MS=15000
# Enable playback session persistence/resume (0/1).
# Enable for faster repeat resolves and resume support.
PLAYBACK_SESSIONS=1
