{
  "name": "streamarena-mobile",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:ios": "expo export --platform ios --output-dir dist --clear",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "node --test tests/*.test.js",
    "doctor": "expo-doctor",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@preeternal/react-native-cookie-manager": "^6.3.3",
    "@react-native-community/slider": "5.2.0",
    "clsx": "^2.1.1",
    "expo": "~56.0.15",
    "expo-blur": "~56.0.3",
    "expo-brightness": "~56.0.0",
    "expo-constants": "~56.0.18",
    "expo-file-system": "~56.0.0",
    "expo-haptics": "~56.0.0",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.14",
    "expo-screen-orientation": "~56.0.5",
    "expo-secure-store": "~56.0.0",
    "expo-splash-screen": "~56.0.12",
    "expo-sqlite": "~56.0.0",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^0.575.0",
    "nativewind": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^3.3.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-video": "^6.10.0",
    "react-native-vlc-media-player": "^1.0.98",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "expo-doctor": "^1.20.0",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-tcp-socket",
          "react-native-vector-icons",
          "react-native-vlc-media-player"
        ]
      }
    }
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "private": true
}
