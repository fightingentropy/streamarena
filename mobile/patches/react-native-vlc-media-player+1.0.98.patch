+- (void)setVolume:(float)value
+{
+    if (_player) {
+        // MobileVLCKit's VLCAudio.volume is an int where 100 == unity (200 == +6dB boost).
+        // Map the JS store's 0..1 value to 0..100 so the gesture's full travel equals a
+        // normal 0–100% range, matching the on-screen volume HUD.
+        [[_player audio] setVolume:(int)roundf(MAX(0.0f, MIN(1.0f, value)) * 100.0f)];
+    }
+}
